# Shared secret used to authenticate the GitHub Actions → Vercel webhook call.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-random-secret-here

# Slack incoming webhook URL for the target channel.
# Create at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=your-slack-incoming-webhook-url

# Full JSON of your GCP service account key, on a single line.
# Download from: GCP Console → IAM & Admin → Service Accounts → your account → Keys → Add Key → JSON
# Then minify: cat key.json | jq -c . | pbcopy
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","private_key_id":"abc123","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"ga-reporter@your-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/ga-reporter%40your-project.iam.gserviceaccount.com"}

# JSON array of GA4 properties to report on.
# Find numeric property IDs in GA4: Admin → Property details → Property ID
GA_PROPERTIES=[{"id":"123456789","name":"Morpheus Site"},{"id":"987654321","name":"Morpheus Blog"}]

# Optional Umami override for the Inference API APP property in GA_PROPERTIES.
# When UMAMI_GA_PROPERTY_ID_INFERENCE_API_APP matches a GA_PROPERTIES id, that
# property is fetched from self-hosted Umami instead of GA4.
UMAMI_GA_PROPERTY_ID_INFERENCE_API_APP=512834239
UMAMI_WEBSITE_ID_INFERENCE_API_APP=9ee22931-b645-4df8-853c-5eba51bfa9e4
UMAMI_HOST=https://umami-production-5f98.up.railway.app
UMAMI_AUTH_TOKEN=your-self-hosted-umami-bearer-token

# Optional X (Twitter) analytics section for the weekly Slack report.
# Requires an X API bearer token that can read the account and recent posts.
X_BEARER_TOKEN=your-x-api-bearer-token
X_USERNAME=morpheusais

# Optional ID-mode override for the previous follower snapshot. By default, the reporter reads
# data/x-followers.jsonl and the GitHub workflow rewrites that file after every report.
X_PREVIOUS_FOLLOWER_IDS=[]

# Optional: set to ids for exact new follow/unfollow split. Default count mode avoids
# paginating the full follower list, which can hit X rate limits on larger accounts.
X_FOLLOWER_SNAPSHOT_MODE=count
